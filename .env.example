# ─── AI Provider Keys (fallback chain: Cerebras → Groq → SambaNova) ─────────
# Place the API key here for respective models

# Primary — Cerebras (fastest, highest quality). Sign up: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Fallback 1 — Groq (free, fast, Llama 3.3 70B). Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Fallback 2 — SambaNova (free, Llama 3.3 70B). Sign up: https://cloud.sambanova.ai
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# ─── Model (Cerebras only — Groq/SambaNova use their own fixed model names) ──
# gpt-oss-120b is Cerebras's flagship reasoning model (fast + powerful)
AI_MODEL=gpt-oss-120b

# ─── Resend (EOI emails) ──────────────────────────────────────────────────────
# Sign up: https://resend.com — Place the API key here for respective models
RESEND_API_KEY=your_resend_api_key_here
# Set this to the inbox that should receive internship EOIs.
OWNER_EMAIL=your_email_here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4173
HOST=127.0.0.1
